---
# ============================================================
# PMDB 密钥配置示例
# ⚠️  复制此文件为 secrets.yml 并填入真实密钥后使用
# ============================================================

# ── API Keys（填写你拥有的提供商密钥，其余留空即可）──────────
# Google Gemini
gemini_api_key: ""
# OpenAI
openai_api_key: ""
# Mistral AI（同时用于 IMDb AI 兜底查询）
mistral_api_key: ""
# Groq
groq_api_key: ""
# Nvidia NIM
nvidia_api_key: ""

# ── OMDb API ─────────────────────────────────────────────────
# 免费注册：https://www.omdbapi.com/apikey.aspx（每日 1000 次）
omdb_api_key: ""

# ============================================================
# 注意：其他所有非敏感配置（模型名称、API 端点、爬虫源、运行参数等）
# 均在 ansible/roles/pmdb/vars/main.yml 中统一管理。
# 如果需要覆盖，可以直接在 secrets.yml 下方添加同名变量，例如：
# translate_provider: "openai"
# max_workers: 5
